PERMANENT_DB_PATH=/path/to/permanent_stock_database.db
TUSHARE_TOKEN=your_tushare_token_here

# OpenClaw stock-agent (5101) + bridge (8601)
OPENCLAW_CLOUD_BRAIN_ONLY=0
OPENCLAW_QA_USE_LLM=1
OPENAI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_MODEL=moonshot-v1-32k
OPENAI_API_KEY=sk-your-kimi-key
# Optional: keep unset unless you really run a local /api/ai/chat service.
# STOCK_LLM_URL=http://127.0.0.1:3443/api/ai/chat

# Telegram bridge
TELEGRAM_BOT_TOKEN=123456789:your_bot_token
# Optional allowlist: comma-separated chat ids
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,-1001234567890

# Notification overrides (optional, used by notification_service.py)
NOTIFY_ENABLED=false
NOTIFY_WECHAT_ENABLED=false
NOTIFY_WECHAT_WEBHOOK=
NOTIFY_DINGTALK_ENABLED=false
NOTIFY_DINGTALK_WEBHOOK=
NOTIFY_SERVERCHAN_ENABLED=false
NOTIFY_SERVERCHAN_SENDKEY=
