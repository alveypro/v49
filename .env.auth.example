# Airivo Authentication Configuration
# 复制此文件为 .env 并填写实际值

# 认证开关（1=启用，0=禁用）
AIRIVO_AUTH_ENABLED=1

# JWT密钥（生产环境请使用强随机密钥）
AIRIVO_JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT过期时间（小时）
AIRIVO_JWT_EXPIRY_HOURS=24

# 认证数据库路径
AIRIVO_AUTH_DB=./data/airivo_auth.db

# Cookie名称
AIRIVO_AUTH_COOKIE=airivo_auth_token

# 审计日志路径
AIRIVO_AUTH_AUDIT_LOG=./logs/airivo_auth_audit.jsonl
AIRIVO_ACTION_AUDIT_LOG=./logs/airivo_action_audit.jsonl
